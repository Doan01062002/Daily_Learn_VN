datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  PREMIUM
  ADMIN
  CTV
  OPERATOR
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

enum ProgressStatus {
  IN_PROGRESS
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id                  String               @id @default(uuid())
  name                String
  email               String               @unique
  password            String?
  isLocked            Boolean              @default(false)
  avatarUrl           String?
  role                Role                 @default(STUDENT)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  // Onboarding
  interestedTopics    String[]
  currentLevel        String?
  commitmentTime      Int?

  // Gamification & Bookmarks
  streakFreezes       Int                  @default(0)
  knowledgePoints     Int                  @default(0)
  savedLessonIds      String[]             @default([])

  // Referrals
  referralCode        String?              @unique
  referredById        String?
  referredBy          User?                @relation("UserReferrals", fields: [referredById], references: [id])
  referrals           User[]               @relation("UserReferrals")
  referralRewarded    Boolean              @default(false)

  // Relations
  progress            UserLessonProgress[]
  streaks             Streak[]
  payments            PaymentTransaction[]
  premiumExpiresAt    DateTime?
  feedbacks           Feedback[]
  submissions         Submission[]         @relation("StudentSubmissions")
  gradedSubmissions   Submission[]         @relation("GradedSubmissions")
  groupMemberships    GroupMembership[]
  badges              UserBadge[]
  weeklyAttempts      WeeklyChallengeAttempt[]
  speedrunRecord      SpeedrunRecord?
}

model Lesson {
  id                  String               @id @default(uuid())
  title               String
  tags                String[]
  sourceDomain        String
  summary             String[]
  actionableStep      String
  level               String
  status              LessonStatus         @default(DRAFT)
  createdAt           DateTime             @default(now())

  // Relations
  quizzes             Quiz[]
  progress            UserLessonProgress[]
  feedbacks           Feedback[]
  assignment          Assignment?
  mediaFiles          MediaFile[]
}

model Quiz {
  id                  String               @id @default(uuid())
  lessonId            String
  lesson              Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question            String
  options             String[]
  correctAnswer       String
  explanation         String
  feedbacks           Feedback[]
}

model UserLessonProgress {
  id                  String               @id @default(uuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId            String
  lesson              Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status              ProgressStatus       @default(IN_PROGRESS)
  score               Int                  @default(0)
  completedAt         DateTime?
  notes               String               @default("")

  @@unique([userId, lessonId])
}

model Streak {
  id                  String               @id @default(uuid())
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak       Int                  @default(0)
  maxStreak           Int                  @default(0)
  lastCompleted       DateTime?
}

model PaymentTransaction {
  id                  String               @id @default(uuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount              Int
  status              PaymentStatus        @default(PENDING)
  txCode              String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  userEmail   String
  userName    String
  action      String   // e.g. "CREATE_LESSON", "APPROVE_PAYMENT", "UPDATE_SETTINGS"
  target      String   // e.g. "Lesson: Vocabulary for Tech", "Payment: BANK123"
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  discountPercent Int
  maxUses         Int
  usedCount       Int      @default(0)
  expiresAt       DateTime
  createdAt       DateTime @default(now())
}

model QuizAttempt {
  id          String   @id @default(uuid())
  userId      String
  lessonId    String
  score       Int
  passed      Boolean
  createdAt   DateTime @default(now())
}

model ScheduledNotification {
  id           String   @id @default(uuid())
  subject      String
  content      String
  target       String
  scheduledFor DateTime
  sent         Boolean  @default(false)
  createdAt    DateTime @default(now())
}

enum FeedbackStatus {
  PENDING
  FIXING
  APPROVED
  DONE
}

enum FeedbackType {
  TYPO
  WRONG_QUIZ
  TRANSLATION
  OTHER
}

enum FeedbackPriority {
  LOW
  MEDIUM
  HIGH
}

model Feedback {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String?
  lesson      Lesson?          @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  quizId      String?
  quiz        Quiz?            @relation(fields: [quizId], references: [id], onDelete: SetNull)
  type        FeedbackType     @default(OTHER)
  content     String
  priority    FeedbackPriority @default(LOW)
  status      FeedbackStatus   @default(PENDING)
  adminNote   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model MediaFile {
  id        String   @id @default(uuid())
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())
  lessonId  String?
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
}

enum AssignmentType {
  WRITING
  SPEAKING
}

model Assignment {
  id          String        @id @default(uuid())
  lessonId    String        @unique
  lesson      Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type        AssignmentType
  prompt      String
  maxScore    Int           @default(100)
  createdAt   DateTime      @default(now())
  submissions Submission[]
}

enum SubmissionStatus {
  SUBMITTED
  GRADING
  GRADED
}

model Submission {
  id           String           @id @default(uuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation("StudentSubmissions", fields: [userId], references: [id], onDelete: Cascade)
  content      String
  status       SubmissionStatus @default(SUBMITTED)
  score        Int?
  comment      String?
  grammarEdits String?
  gradedAt     DateTime?
  gradedById   String?
  gradedBy     User?            @relation("GradedSubmissions", fields: [gradedById], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String   @unique
  otpCode   String
  name      String
  password  String   // Hashed password
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model StudyGroup {
  id          String            @id @default(uuid())
  name        String
  code        String            @unique
  createdById String
  createdAt   DateTime          @default(now())
  memberships GroupMembership[]
  reactions   GroupReaction[]
}

model GroupMembership {
  id        String     @id @default(uuid())
  groupId   String
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime   @default(now())

  @@unique([groupId, userId])
}

model GroupReaction {
  id         String     @id @default(uuid())
  groupId    String
  group      StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId   String
  senderName String
  receiverId String
  emoji      String     // "🔥", "👏", "💪"
  createdAt  DateTime   @default(now())
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId    String   // e.g. "FIRST_LESSON", "14_STREAK", "TECH_CHAMP"
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model WeeklyChallenge {
  id           String                   @id @default(uuid())
  title        String
  description  String
  weekNumber   Int                      @unique
  questions    Json                     // Array of { question, options, correctAnswer, explanation }
  startTime    DateTime
  endTime      DateTime
  rewardPoints Int                      @default(100)
  createdAt    DateTime                 @default(now())
  attempts     WeeklyChallengeAttempt[]
}

model WeeklyChallengeAttempt {
  id          String          @id @default(uuid())
  challengeId String
  challenge   WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  score       Int             // e.g. 0 to 10
  completedAt DateTime        @default(now())

  @@unique([challengeId, userId])
}

model SpeedrunRecord {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score       Int      // e.g. 0 to 5 (number of correct answers)
  timeSeconds Float    // e.g. 14.5 seconds
  createdAt   DateTime @default(now())
}
